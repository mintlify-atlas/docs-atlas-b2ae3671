  "keyFeatures": [
    "Layout-preserving PDF translation for scanned/image-based PDFs",
    "Complex inline math formula rendering via Typst",
    "Multiple OCR providers: MinerU and PaddleOCR",
    "Full pipeline: OCR → Normalize → Translate → Render",
    "Custom translation rules, glossaries, and profiles",
    "Output formats: translated PDF, Markdown, and ZIP bundle",
    "Web UI, desktop app (Windows/macOS/Linux), and REST API",
    "Docker deployment for team/LAN use",
    "Configurable render options (font, DPI, page ranges)",
    "Translation diagnostics with per-item replay support"
  ],
